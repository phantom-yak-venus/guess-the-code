#!/usr/bin/env bash
set -euo pipefail

ENV_FILE="/etc/guess-the-code.env"
CONTAINER_NAME="guess-the-code"
STOP_TIMEOUT_SECONDS="15"

if [ -f "$ENV_FILE" ]; then
  set -a
  source "$ENV_FILE"
  set +a
  CONTAINER_NAME="${CONTAINER_NAME:-guess-the-code}"
fi

echo "Stopping timer..."
sudo systemctl stop guess-the-code.timer 2>/dev/null || true

echo "Disabling timer autostart..."
sudo systemctl disable guess-the-code.timer 2>/dev/null || true

echo "Trying graceful Docker stop for ${STOP_TIMEOUT_SECONDS}s..."
timeout $((STOP_TIMEOUT_SECONDS + 5)) sudo docker stop -t "$STOP_TIMEOUT_SECONDS" "$CONTAINER_NAME" 2>/dev/null || true

echo "Force removing Docker container if it still exists..."
sudo docker rm -f "$CONTAINER_NAME" 2>/dev/null || true

echo "Stopping systemd service with short timeout..."
timeout 20 sudo systemctl stop guess-the-code.service 2>/dev/null || true

echo "Killing service processes if systemd is still stopping..."
sudo systemctl kill --kill-who=all --signal=SIGKILL guess-the-code.service 2>/dev/null || true

echo "Resetting failed state..."
sudo systemctl reset-failed guess-the-code.service 2>/dev/null || true

echo
echo "Current status:"
systemctl status guess-the-code.timer --no-pager 2>/dev/null || true
systemctl status guess-the-code.service --no-pager 2>/dev/null || true

echo
echo "Docker containers:"
sudo docker ps --filter "name=${CONTAINER_NAME}"
