# Docker image name
IMAGE_NAME=headless-timer

# Docker container name
CONTAINER_NAME=guess-the-code

# YouTube RTMP stream key
STREAM_KEY=replace_me

# YouTube channel id
CHANNEL_ID=replace_me

# Schedule: run every N minutes
RUN_EVERY_MINUTES=5

# How long one run should work, in seconds
RUNTIME_SECONDS=120

# How long Docker should wait for graceful shutdown, in seconds
STOP_TIMEOUT_SECONDS=120

# Docker network mode.
# host is useful for avoiding Docker bridge/DNS issues.
DOCKER_NETWORK=host

# Extra Node.js options
NODE_OPTIONS=--dns-result-order=ipv4first
