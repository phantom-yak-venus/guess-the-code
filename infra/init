#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENV_FILE="${SCRIPT_DIR}/env"

SYSTEM_ENV_FILE="/etc/guess-the-code.env"
SERVICE_FILE="/etc/systemd/system/guess-the-code.service"
TIMER_FILE="/etc/systemd/system/guess-the-code.timer"

if [ ! -f "$ENV_FILE" ]; then
  echo "ERROR: env file not found: $ENV_FILE"
  echo "Create it from env.example:"
  echo "  cp infra/env.example infra/env"
  exit 1
fi

# Load env variables
set -a
source "$ENV_FILE"
set +a

IMAGE_NAME="${IMAGE_NAME:-headless-timer}"
CONTAINER_NAME="${CONTAINER_NAME:-guess-the-code}"
RUN_EVERY_MINUTES="${RUN_EVERY_MINUTES:-5}"
RUNTIME_SECONDS="${RUNTIME_SECONDS:-120}"
STOP_TIMEOUT_SECONDS="${STOP_TIMEOUT_SECONDS:-120}"
DOCKER_NETWORK="${DOCKER_NETWORK:-host}"
NODE_OPTIONS="${NODE_OPTIONS:---dns-result-order=ipv4first}"

if [ -z "${STREAM_KEY:-}" ] || [ "$STREAM_KEY" = "replace_me" ]; then
  echo "ERROR: STREAM_KEY is empty or replace_me in infra/env"
  exit 1
fi

if [ -z "${CHANNEL_ID:-}" ] || [ "$CHANNEL_ID" = "replace_me" ]; then
  echo "ERROR: CHANNEL_ID is empty or replace_me in infra/env"
  exit 1
fi

echo "Installing env to ${SYSTEM_ENV_FILE}..."

sudo tee "$SYSTEM_ENV_FILE" > /dev/null <<ENVEOF
IMAGE_NAME=${IMAGE_NAME}
CONTAINER_NAME=${CONTAINER_NAME}
STREAM_KEY=${STREAM_KEY}
CHANNEL_ID=${CHANNEL_ID}
YOUTUBE_API_KEY=${YOUTUBE_API_KEY:-}
NODE_OPTIONS=${NODE_OPTIONS}
ENVEOF

sudo chmod 600 "$SYSTEM_ENV_FILE"

echo "Writing systemd service to ${SERVICE_FILE}..."

sudo tee "$SERVICE_FILE" > /dev/null <<SERVICEEOF
[Unit]
Description=Guess The Code YouTube stream container
After=docker.service network-online.target
Requires=docker.service
Wants=network-online.target

[Service]
Type=simple

EnvironmentFile=${SYSTEM_ENV_FILE}

# Remove old container if it exists after crash/reboot.
ExecStartPre=-/usr/bin/docker rm -f ${CONTAINER_NAME}

# Run container.
# --rm removes the container after exit.
# --env-file passes STREAM_KEY, CHANNEL_ID, YOUTUBE_API_KEY, NODE_OPTIONS.
ExecStart=/usr/bin/docker run --rm \\
  --name ${CONTAINER_NAME} \\
  --network ${DOCKER_NETWORK} \\
  --env-file ${SYSTEM_ENV_FILE} \\
  ${IMAGE_NAME}

# Graceful stop:
# docker stop sends SIGTERM first, waits ${STOP_TIMEOUT_SECONDS}s,
# then sends SIGKILL if the container did not exit.
ExecStop=/usr/bin/docker stop -t ${STOP_TIMEOUT_SECONDS} ${CONTAINER_NAME}

# Max duration of one stream run.
RuntimeMaxSec=${RUNTIME_SECONDS}

# Must be bigger than STOP_TIMEOUT_SECONDS.
TimeoutStopSec=$((STOP_TIMEOUT_SECONDS + 30))

Restart=no
KillMode=mixed

[Install]
WantedBy=multi-user.target
SERVICEEOF

echo "Writing systemd timer to ${TIMER_FILE}..."

sudo tee "$TIMER_FILE" > /dev/null <<TIMEREOF
[Unit]
Description=Run Guess The Code every ${RUN_EVERY_MINUTES} minutes

[Timer]
# Run every N minutes: 00, 05, 10, 15...
OnCalendar=*-*-* *:00/${RUN_EVERY_MINUTES}:00

# Do not run missed launches after server downtime.
Persistent=false

Unit=guess-the-code.service

[Install]
WantedBy=timers.target
TIMEREOF

echo "Reloading systemd..."
sudo systemctl daemon-reload

echo "Done."
echo
echo "Next commands:"
echo "  infra/start"
echo "  infra/stop"
echo
echo "Check generated units:"
echo "  systemctl cat guess-the-code.service"
echo "  systemctl cat guess-the-code.timer"
